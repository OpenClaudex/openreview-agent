# Copy this structure to ~/.openreview.env and fill values locally.
# Do not commit real usernames, passwords, or tokens.

# Preferred: use an OpenReview token when available.
export OPENREVIEW_TOKEN='your-openreview-token'

# Or use username/password instead of token.
# export OPENREVIEW_USERNAME='you@example.com'
# export OPENREVIEW_PASSWORD='your-openreview-password'

# Optional; defaults to https://api2.openreview.net
# export OPENREVIEW_BASE_URL='https://api2.openreview.net'
